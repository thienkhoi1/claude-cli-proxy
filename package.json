{
  "name": "@thienkhoi1/claude-cli-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local HTTP/SSE gateway that wraps the Claude CLI as an OpenAI-compatible API.",
  "license": "MIT",
  "author": "thienkhoi1",
  "homepage": "https://github.com/thienkhoi1/claude-cli-proxy",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/thienkhoi1/claude-cli-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/thienkhoi1/claude-cli-proxy/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/server.js",
  "bin": {
    "claude-cli-proxy": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "smoke": "tsx src/test-auth.ts",
    "dev": "PROXY_DATA_DIR=${PROXY_DATA_DIR:-$PWD} tsx watch src/server.ts",
    "start": "PROXY_DATA_DIR=${PROXY_DATA_DIR:-$PWD} tsx src/server.ts",
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "better-sqlite3": "^11.3.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
