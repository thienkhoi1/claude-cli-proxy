# claude-cli-proxy — end-user configuration
#
# Copy this to either:
#   ~/.claude-cli-proxy/.env   (default lookup path)
#   ./.env                     (cwd at startup)
# Or point to it explicitly with PROXY_ENV_FILE=/path/to/.env
#
# All values below are OPTIONAL — the proxy boots fine with no .env at all.
# Uncomment only what you want to override. Existing environment variables
# always take precedence over this file.

# ── Bind address / port ─────────────────────────────────────────────────────
# Address the HTTP server listens on. Default keeps it local-only.
# PROXY_HOST=127.0.0.1
# PROXY_PORT=3000

# ── Default model ───────────────────────────────────────────────────────────
# Used when a client request doesn't specify a model (e.g. OpenClaw sends
# `khoi-local`). Set to any model id the local `claude` CLI accepts.
# PROXY_DEFAULT_MODEL=claude-sonnet-4-6

# ── Concurrency + rate-limit retry ─────────────────────────────────────────
# Max concurrent `claude` subprocesses. Bursty multi-agent fan-out can trip
# short-window rate limits; the cap queues excess requests instead.
# PROXY_MAX_CONCURRENCY=2
# Transparent retry on rate_limit / server_error errors that arrive before any
# content has streamed. Exponential backoff: base, base*2, base*4, …
# PROXY_RATE_RETRY_MAX=3
# PROXY_RATE_RETRY_BASE_MS=30000

# ── Data directory ──────────────────────────────────────────────────────────
# Where sessions.db, workspaces/, and projects.json live. Default is
# ~/.claude-cli-proxy. The .env file lookup also checks this path.
# PROXY_DATA_DIR=/absolute/path/to/data

# ── Claude CLI binary ──────────────────────────────────────────────────────
# Path to the official `claude` CLI. Auto-detected from PATH and common
# install locations; set explicitly if you have multiple installs.
# CLAUDE_CLI_PATH=/opt/homebrew/bin/claude
